{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn", "oxc", "import"],
	"options": {
		"typeCheck": true,
		"typeAware": true
	},
	"env": {
		"builtin": true,
		"es2022": true,
		"browser": true,
		"node": true
	},
	"ignorePatterns": ["dist/", "node_modules/", ".angular/", "**/*.html"],
	"rules": {}
}
