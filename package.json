{
	"name": "angular-web-worker-resource-workspace",
	"version": "1.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "pnpm --filter=angular-web-worker-resource build",
		"watch": "pnpm --filter=angular-web-worker-resource watch",
		"test": "pnpm --filter=angular-web-worker-resource test",
		"test:watch": "pnpm --filter=angular-web-worker-resource test:watch",
		"serve": "pnpm --filter=app serve",
		"serve-extended": "pnpm --filter=app serve-extended",
		"build-app": "pnpm --filter=app build",
		"check": "oxlint . && oxfmt --check .",
		"format": "oxlint --fix . && oxfmt ."
	},
	"devDependencies": {
		"@angular-devkit/build-angular": "^21.2.7",
		"@angular-devkit/core": "^21.2.7",
		"@angular/build": "^21.2.7",
		"@angular/cli": "^21.2.7",
		"@angular/compiler-cli": "^21.2.8",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-angular": "^20.5.0",
		"@release-it/bumper": "^7.0.5",
		"@types/node": "^24.12.2",
		"del-cli": "^7.0.0",
		"lefthook": "^2.1.5",
		"ng-packagr": "^21.2.2",
		"oxfmt": "^0.45.0",
		"oxlint": "^1.60.0",
		"oxlint-tsgolint": "^0.21.0",
		"release-it": "^19.2.4",
		"typescript": "5.9.3",
		"vitest": "^4.1.4"
	},
	"engines": {
		"node": ">=24"
	}
}
